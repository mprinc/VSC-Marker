{
  // ============================================================
  //  MARKER EXTENSION — DEBUG / CONFIGURATION REFERENCE
  // ============================================================
  //
  //  DEBUGGING STRATEGY (finding what crashes other extensions):
  //
  //  STEP 1: Set "marker.enabled" to false
  //          → all Marker features are OFF, commands fall through to VS Code defaults
  //          → verify: do other extensions (Copilot, etc.) still crash?
  //          → if YES: Marker is NOT the problem
  //          → if NO: continue to Step 2
  //
  //  STEP 2: Set "marker.enabled" to true, but switch ALL keys to safe mode:
  //          → "marker.bindings.keys.enter.mode": "provider"    (default, crash-safe)
  //          → "marker.bindings.keys.tab.mode": "auto-listener" (crash-safe)
  //          → "marker.bindings.keys.paste.mode": "provider"    (default, crash-safe)
  //          → verify: still crashes?
  //          → if NO: one of the key overrides was the culprit → go to Step 3
  //
  //  STEP 3: Switch ONE key to "keybinding-override" at a time:
  //          → first "marker.bindings.keys.paste.mode": "keybinding-override" → test
  //          → then  "marker.bindings.keys.enter.mode": "keybinding-override" → test
  //          → then  "marker.bindings.keys.tab.mode": "tab-override"          → test
  //          → the one that causes crash is the culprit
  //
  //  STEP 4: If key overrides are not the problem, enable features one by one:
  //          → formatting, preview, export, etc.
  //
  //  COPY these settings into your VS Code settings.json:
  //    Cmd+Shift+P → "Preferences: Open User Settings (JSON)"
  // ============================================================

  // ─── VS CODE PASTE SYSTEM (REQUIRED FOR SMART PASTE) ──────
  // Marker v0.0.17+ uses DocumentPasteEditProvider instead of Cmd+V
  // keybinding override. This prevents paste from being blocked when
  // the extension host crashes.
  //
  // IMPORTANT: These are VS Code settings, NOT Marker settings.
  // They must be enabled for Marker's smart paste to work.
  //
  // editor.pasteAs.enabled: master switch for ALL paste providers.
  //   If false, VS Code ignores all DocumentPasteEditProviders.
  //   Default: true. If you set it to false previously (to avoid
  //   conflicts with old keybinding approach), re-enable it.
  "editor.pasteAs.enabled": true,

  // editor.pasteAs.preferences: which paste provider kind to auto-apply.
  //   Our provider registers kind "text.marker.smartPaste":
  //     - "text" = VS Code built-in base (DocumentDropOrPasteEditKind.Text)
  //     - "markdown" = our namespace (flexible, our choice)
  //     - "smartPaste" = our feature name (flexible, our choice)
  //   When this matches, VS Code auto-applies our provider without
  //   showing a paste widget. If empty [] or missing, VS Code does
  //   plain paste and shows widget with alternatives.
  //
  //   Set per-language via [markdown] scope so it only affects .md files:
  //   "[markdown]": {
  //     "editor.pasteAs.preferences": ["text.marker.smartPaste"]
  //   }
  //
  //   Marker sets this via configurationDefaults in package.json,
  //   but user settings OVERRIDE configurationDefaults. If you have
  //   "editor.pasteAs.preferences": [] in your settings, delete it
  //   or set it explicitly for markdown.

  // Also disable VS Code's built-in markdown file paste if it
  // conflicts with Marker's image paste:
  // "markdown.editor.filePaste.enabled": "never",
  // "markdown.editor.filePaste.copyIntoWorkspace": "never",

  // ─── MASTER SWITCH ─────────────────────────────────────────
  // Disables ALL Marker functionality.
  // All intercepted keys (Enter, Tab, Cmd+V) fall through to VS Code defaults.
  // All formatting commands become no-ops.
  "marker.enabled": true,

  // ─── KEY INTERCEPTIONS (HIGHEST RISK) ──────────────────────
  // These override fundamental keys that other extensions also listen to.
  // Most likely to cause conflicts with Copilot, Copilot Chat, etc.
  // When disabled, the key falls through to normal VS Code behavior.

  // Enter key: smart list continuation (- item → Enter → - new item)
  // Three modes:
  //   "provider"            — onEnterRules (declarative) + listener cleanup/outdent.
  //                           Crash-safe: Enter always works even if host dies.
  //   "keybinding-override" — Enter keybinding → marker.onEnter command.
  //                           Full features but Enter is blocked if host crashes.
  //   "manual"              — No Enter override, no listener cleanup.
  //                           Use marker.onEnter from Command Palette.
  "marker.bindings.keys.enter.mode": "provider",

  // Tab key: how list indentation works.
  // Three modes:
  //   "tab-override"   — Tab/Shift+Tab override. Best UX (instant indent).
  //                      Risk: if extension host crashes, Tab is blocked until
  //                      you set marker.enabled=false in Settings.
  //   "auto-listener"  — No Tab override. Native Tab inserts indent, Marker
  //                      auto-renumbers via onDidChangeTextDocument listener
  //                      after 400ms. Crash-safe: Tab always works.
  //   "manual"         — No Tab override, no auto-renumber on Tab. Use
  //                      marker.indentList / marker.outdentList from Command
  //                      Palette or bind your own shortcut in keybindings.json.
  "marker.bindings.keys.tab.mode": "tab-override",

  // Cmd+V / Ctrl+V: smart paste (auto-detect URL or image in clipboard)
  // Three modes:
  //   "provider"            — DocumentPasteEditProvider. Hooks into paste
  //                           pipeline without overriding Cmd+V. Crash-safe.
  //                           Requires editor.pasteAs.enabled: true (see above).
  //   "keybinding-override" — Cmd+V keybinding → marker.smartPaste command.
  //                           Full features but Cmd+V is blocked if host crashes.
  //   "manual"              — No paste override. Use Ctrl+Alt+V (pasteLink)
  //                           or Cmd+Alt+I (pasteImage) manually.
  "marker.bindings.keys.paste.mode": "provider",

  // ─── PASTE SUB-FEATURES ────────────────────────────────────
  // These only matter when marker.bindings.keys.paste.mode is not "manual".

  // Auto-detect URL in clipboard and wrap selected text as [text](url)
  "marker.pasteLink.enabled": true,

  // Auto-detect image in clipboard and save as file + insert ![text](file.png)
  // Risk: spawns osascript/JXA process to read clipboard image
  "marker.pasteImage.enabled": true,

  // Auto-name pattern when pasting image without selection.
  // D = digit placeholder (zero-padded to the number of D's).
  // Examples: "image-DDD" → image-001, "slika-DD" → slika-01
  "marker.pasteImage.autoName": "image-DDD",

  // ─── ENTER SUB-FEATURES ────────────────────────────────────
  // These only matter when marker.bindings.keys.enter.mode is not "manual".

  // Auto-continue bullet lists (- item, + item)
  "marker.autoList.bullet.enabled": true,

  // Auto-continue numbered lists (1. item)
  "marker.autoList.numbered.enabled": true,

  // Numbered list mode: "auto" (smart) or "increment" (always +1)
  "marker.autoList.numbered.mode": "auto",

  // ─── FORMATTING COMMANDS (LOW RISK) ────────────────────────
  // These use dedicated shortcuts (Cmd+B, Cmd+I, etc.)
  // Only triggered by explicit user action, not by typing.
  // Unlikely to cause crashes, but can be disabled for completeness.

  "marker.formatting.bold": true,           // Cmd+B
  "marker.formatting.italic": true,         // Cmd+I
  "marker.formatting.underline": true,      // Cmd+U
  "marker.formatting.strikethrough": true,  // Alt+S
  "marker.formatting.codeSpan": true,       // Cmd+E
  "marker.formatting.codeBlock": true,      // Cmd+Shift+E

  // ─── HEADING (LOW RISK) ────────────────────────────────────
  "marker.heading.enabled": true,           // Cmd+Shift+] / Cmd+Shift+[

  // ─── TASK TOGGLE (LOW RISK) ────────────────────────────────
  "marker.task.enabled": true,              // Alt+C

  // ─── TABLE (LOW RISK) ──────────────────────────────────────
  "marker.table.enabled": true,             // Cmd+Alt+T

  // ─── PREVIEW (MEDIUM RISK) ─────────────────────────────────
  // Opens a side panel with live preview.
  // Risk: registers onDidChangeTextDocument listener that re-renders HTML
  //       on every keystroke (debounced). This generates webview updates.
  "marker.preview.enabled": true,           // Cmd+Shift+V

  // Debounce delay for preview updates (ms). Higher = less frequent updates.
  "marker.preview.debounceMs": 300,

  // ─── EXPORT (LOW RISK) ─────────────────────────────────────
  "marker.export.enabled": true,            // Command palette only

  // ─── OTHER ─────────────────────────────────────────────────
  // Default language tag for code blocks
  "marker.codeBlock.defaultLanguage": "sh"
}
