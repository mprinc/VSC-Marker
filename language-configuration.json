{
  "onEnterRules": [
    {
      "beforeText": "^\\s*-\\s+\\[[ x]\\]\\s+.+$",
      "action": { "indent": "none", "appendText": "- [ ] " }
    },
    {
      "beforeText": "^\\s*-\\s+.+$",
      "action": { "indent": "none", "appendText": "- " }
    },
    {
      "beforeText": "^\\s*\\*\\s+.+$",
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": "^\\s*\\+\\s+.+$",
      "action": { "indent": "none", "appendText": "+ " }
    },
    {
      "beforeText": "^\\s*\\d+\\.\\s+.+$",
      "action": { "indent": "none", "appendText": "1. " }
    }
  ]
}
