{
  "name": "marker",
  "displayName": "Marker",
  "publisher": "mprinc",
  "description": "Markdown extension for pasting links and images over selected text",
  "version": "0.0.16",
  "repository": {
    "type": "git",
    "url": "https://github.com/mprinc/VSC-Marker"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "marker.pasteLink",
        "title": "Marker: Paste Link"
      },
      {
        "command": "marker.pasteImage",
        "title": "Marker: Paste Image"
      },
      {
        "command": "marker.smartPaste",
        "title": "Marker: Smart Paste"
      },
      {
        "command": "marker.onEnter",
        "title": "Marker: Smart Enter"
      },
      {
        "command": "marker.showPreview",
        "title": "Marker: Show Preview"
      },
      {
        "command": "marker.toggleBold",
        "title": "Marker: Toggle Bold"
      },
      {
        "command": "marker.toggleItalic",
        "title": "Marker: Toggle Italic"
      },
      {
        "command": "marker.toggleUnderline",
        "title": "Marker: Toggle Underline"
      },
      {
        "command": "marker.createTable",
        "title": "Marker: Create/Convert Table"
      },
      {
        "command": "marker.toggleStrikethrough",
        "title": "Marker: Toggle Strikethrough"
      },
      {
        "command": "marker.toggleCodeSpan",
        "title": "Marker: Toggle Code Span"
      },
      {
        "command": "marker.toggleCodeBlock",
        "title": "Marker: Toggle Code Block"
      },
      {
        "command": "marker.headingUp",
        "title": "Marker: Heading Level Up"
      },
      {
        "command": "marker.headingDown",
        "title": "Marker: Heading Level Down"
      },
      {
        "command": "marker.toggleTask",
        "title": "Marker: Toggle Task Checkbox"
      },
      {
        "command": "marker.indentList",
        "title": "Marker: Indent List"
      },
      {
        "command": "marker.outdentList",
        "title": "Marker: Outdent List"
      },
      {
        "command": "marker.exportHtml",
        "title": "Marker: Export to HTML"
      },
      {
        "command": "marker.deleteImage",
        "title": "Marker: Delete Image (file + reference)"
      }
    ],
    "keybindings": [
      {
        "command": "marker.pasteLink",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.pasteImage",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.smartPaste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.onEnter",
        "key": "enter",
        "when": "marker.active && editorTextFocus && editorLangId == markdown && !suggestWidgetVisible && !editorHasMultipleSelections && !inSnippetMode"
      },
      {
        "command": "marker.showPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "marker.active && editorLangId == markdown"
      },
      {
        "command": "marker.toggleBold",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.toggleItalic",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.toggleUnderline",
        "key": "ctrl+u",
        "mac": "cmd+u",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.createTable",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.toggleStrikethrough",
        "key": "alt+s",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.toggleCodeSpan",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.toggleCodeBlock",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.headingUp",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.headingDown",
        "key": "ctrl+shift+[",
        "mac": "cmd+shift+[",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.toggleTask",
        "key": "alt+c",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "marker.indentList",
        "key": "tab",
        "when": "marker.active && editorTextFocus && editorLangId == markdown && !suggestWidgetVisible && !editorHasMultipleSelections && !inSnippetMode && !inlineSuggestionVisible"
      },
      {
        "command": "marker.outdentList",
        "key": "shift+tab",
        "when": "marker.active && editorTextFocus && editorLangId == markdown && !suggestWidgetVisible && !editorHasMultipleSelections && !inSnippetMode && !inlineSuggestionVisible"
      },
      {
        "command": "marker.deleteImage",
        "key": "ctrl+shift+delete",
        "mac": "cmd+shift+backspace",
        "when": "marker.active && editorTextFocus && editorLangId == markdown"
      }
    ],
    "configuration": {
      "title": "Marker",
      "properties": {
        "marker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch: disable ALL Marker functionality (keys fall through to VS Code defaults)"
        },
        "marker.override.enter": {
          "type": "boolean",
          "default": true,
          "description": "Override Enter key for smart list continuation. When false, Enter behaves normally."
        },
        "marker.override.tab": {
          "type": "boolean",
          "default": true,
          "description": "Override Tab/Shift+Tab for list indent/outdent. When false, Tab behaves normally."
        },
        "marker.override.paste": {
          "type": "boolean",
          "default": true,
          "description": "Override Cmd+V/Ctrl+V for smart paste. When false, paste behaves normally."
        },
        "marker.pasteLink.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect URL in clipboard and wrap selected text as Markdown link"
        },
        "marker.pasteLink.relativePaths": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "always", "never"],
          "enumDescriptions": [
            "Smart: relative paths for files inside workspace, absolute (file://) for files outside",
            "Always use relative paths",
            "Always use absolute paths (file://)"
          ],
          "description": "How to handle file paths when pasting links. Cmd+Alt+V inverts the behavior."
        },
        "marker.pasteImage.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect image in clipboard and save as file + insert Markdown image"
        },
        "marker.pasteImage.autoName": {
          "type": "string",
          "default": "слика-DDD",
          "description": "Auto-name pattern when pasting image without selection. D = digit placeholder (zero-padded). Examples: 'image-DDD' → image-001, 'слика-DD' → slika-01, 'screenshot-DDDD' → screenshot-0001"
        },
        "marker.autoList.bullet.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Auto-continue bullet lists (- or +) on Enter"
        },
        "marker.autoList.numbered.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Auto-continue numbered lists on Enter"
        },
        "marker.autoList.numbered.mode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "increment"
          ],
          "enumDescriptions": [
            "Smart: if last two numbers are the same, keep same; if different, increment",
            "Always increment the number"
          ],
          "description": "How to determine the next number in a numbered list"
        },
        "marker.formatting.bold": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+B bold toggle"
        },
        "marker.formatting.italic": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+I italic toggle"
        },
        "marker.formatting.underline": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+U underline toggle"
        },
        "marker.formatting.strikethrough": {
          "type": "boolean",
          "default": true,
          "description": "Enable Alt+S strikethrough toggle"
        },
        "marker.formatting.codeSpan": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+E code span toggle"
        },
        "marker.formatting.codeBlock": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+Shift+E code block toggle"
        },
        "marker.heading.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+Shift+]/[ heading level up/down"
        },
        "marker.task.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Alt+C task checkbox toggle"
        },
        "marker.table.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+Alt+T table creation"
        },
        "marker.preview.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Cmd+Shift+V Markdown preview"
        },
        "marker.preview.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay (ms) for live preview updates. Higher = fewer updates."
        },
        "marker.export.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Export to HTML command"
        },
        "marker.codeBlock.defaultLanguage": {
          "type": "string",
          "default": "sh",
          "description": "Default language for code blocks (e.g. sh, typescript, python)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "markdown-it": "^14.1.1"
  }
}
